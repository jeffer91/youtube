{
  "name": "auto-video-jeff",
  "version": "0.3.4",
  "description": "App modular para editar videos automaticamente, con audio, transcripcion, subtitulos, textos flotantes, edicion dinamica, visuales, sonidos automaticos y progreso real.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "electron": "electron .",
    "dev": "electron .",
    "server": "node server.js",
    "web": "node server.js",
    "check:bloque1": "node scripts/verificar-bloque-1.js",
    "check:bloque2": "node scripts/verificar-bloque-2.js",
    "check:diagnostico": "node scripts/verificar-diagnostico-automatico.js",
    "check:integracion-final": "node scripts/verificar-integracion-final.js",
    "check:progreso": "node scripts/verificar-progreso-real.js",
    "check:todo": "node scripts/verificar-todo.js",
    "check:transcripcion": "node scripts/verificar-integracion-transcripcion.js",
    "test:transcripcion-manual": "node scripts/probar-transcripcion-manual.js",
    "test:gemini-fallback": "node scripts/probar-fallback-gemini.js",
