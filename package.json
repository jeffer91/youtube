    "express": "^4.19.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "electron": "^31.0.0"
  }
