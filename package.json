{
  "name": "auto-video-jeff",
  "version": "0.3.2",
  "description": "App modular para editar videos automaticamente, con audio, transcripción, subtítulos, textos flotantes, edición dinámica, visuales, sonidos automáticos y progreso real.",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "electron": "electron .",
    "dev": "electron .",
    "server": "node server.js",
    "web": "node server.js",
    "check:diagnostico": "node scripts/verificar-diagnostico-automatico.js",
    "check:integracion-final": "node scripts/verificar-integracion-final.js",
    "check:progreso": "node scripts/verificar-progreso-real.js",
    "check:todo": "node scripts/verificar-todo.js",
    "check:transcripcion": "node scripts/verificar-integracion-transcripcion.js",
    "check:plan-edicion": "node scripts/verificar-plan-edicion.js",
    "check:revision": "node scripts/verificar-revision.js",
    "check:flujo-draft": "node scripts/verificar-flujo-draft.js",
    "check:render-plan": "node scripts/verificar-render-plan.js",
    "check:perfiles": "node scripts/verificar-perfiles.js",
    "check:inteligencia": "node scripts/verificar-inteligencia.js",
    "check:ui-inteligencia": "node scripts/verificar-ui-inteligencia.js",
    "test:transcripcion-manual": "node scripts/probar-transcripcion-manual.js",
    "test:gemini-fallback": "node scripts/probar-fallback-gemini.js",
    "test:drawtext": "node scripts/probar-drawtext.js"
  },
  "keywords": [
    "video",
    "ffmpeg",
    "tiktok",
    "editor",
    "modular",
    "electron",
    "transcripcion",
    "subtitulos",
    "gemini",
    "edicion-dinamica",
    "automatizacion",
    "progreso-real"
  ],
  "author": "Jefferson Villarreal",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "electron": "^31.0.0"
  }
}
