{
  "nombre": "audio-voz-segura",
  "descripcion": "Preset conservador para voz hablada: evita ruido artificial, conserva sincronía y solo mejora lo necesario.",
  "tipo": "limpieza-audio",
  "version": "2.2.0",
  "activoPorDefecto": true,
  "audio": {
    "codecAudio": "aac",
    "audioBitrate": "192k",
    "frecuenciaMuestreo": 48000,
    "canales": 2,
    "extension": ".m4a"
  },
  "filtros": {
    "highpassHz": 80,
    "lowpassHz": 13000,
    "inicioSeguro": {
      "activo": true,
      "duracionFadeIn": 0.18,
      "evitarSonidosAntesDe": 0.85
    },
    "reduccionRuido": {
      "activo": true,
      "noiseFloor": -34,
      "noiseType": "w"
    },
    "realceVoz": {
      "activo": true,
      "graves": {
        "frecuencia": 160,
        "ganancia": -0.8,
        "ancho": 1.0
      },
      "cuerpo": {
        "frecuencia": 420,
        "ganancia": 0.7,
        "ancho": 1.0
      },
      "presencia": {
        "frecuencia": 2600,
        "ganancia": 1.6,
        "ancho": 1.0
      },
      "claridad": {
        "frecuencia": 5200,
        "ganancia": 1.1,
        "ancho": 1.0
      }
    },
    "compresor": {
      "activo": true,
      "threshold": -24,
      "ratio": 2.6,
      "attack": 8,
      "release": 180,
      "makeup": 2.2
    },
    "normalizacionDinamica": {
      "activo": false,
      "frameLen": 120,
      "gaussianSize": 9,
      "peak": 0.92,
      "maxGain": 6
    },
    "volumenFinal": {
      "activo": true,
      "ganancia": 1.0
    },
    "normalizacionFinal": {
      "activo": true,
      "integratedLoudness": -16,
      "truePeak": -1.5,
      "loudnessRange": 9
    }
  },
  "notas": [
    "Este preset prioriza no agregar ruido que no existía en el video inicial.",
    "Evita normalización dinámica agresiva porque puede levantar ruido de fondo.",
    "Mantiene un fade-in corto para evitar golpes al inicio.",
    "La salida debe conservar sincronía y usar audio original cuando sea más seguro."
  ]
}
