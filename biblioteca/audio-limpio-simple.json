{
  "nombre": "audio-voz-al-frente",
  "descripcion": "Preset profesional para voz hablada: acerca la voz, mejora nitidez, controla ruido y deja volumen fuerte para redes sociales.",
  "tipo": "limpieza-audio",
  "version": "2.0.0",
  "activoPorDefecto": true,
  "audio": {
    "codecAudio": "aac",
    "audioBitrate": "224k",
    "frecuenciaMuestreo": 48000,
    "canales": 2,
    "extension": ".m4a"
  },
  "filtros": {
    "highpassHz": 95,
    "lowpassHz": 14500,
    "reduccionRuido": {
      "activo": true,
      "noiseFloor": -26,
      "noiseType": "w"
    },
    "realceVoz": {
      "activo": true,
      "graves": {
        "frecuencia": 180,
        "ganancia": -1.5,
        "ancho": 1.0
      },
      "cuerpo": {
        "frecuencia": 420,
        "ganancia": 1.2,
        "ancho": 1.1
      },
      "presencia": {
        "frecuencia": 2600,
        "ganancia": 4.5,
        "ancho": 1.0
      },
      "claridad": {
        "frecuencia": 5200,
        "ganancia": 3.2,
        "ancho": 1.0
      }
    },
    "compresor": {
      "activo": true,
      "threshold": -28,
      "ratio": 5.5,
      "attack": 4,
      "release": 140,
      "makeup": 7
    },
    "normalizacionDinamica": {
      "activo": true,
      "frameLen": 90,
      "gaussianSize": 11,
      "peak": 0.95,
      "maxGain": 18
    },
    "volumenFinal": {
      "activo": true,
      "ganancia": 1.18
    },
    "normalizacionFinal": {
      "activo": true,
      "integratedLoudness": -12.5,
      "truePeak": -1,
      "loudnessRange": 7
    }
  },
  "notas": [
    "Este preset no solo limpia: tambien coloca la voz mas cerca y mas clara.",
    "Realza presencia y claridad para que la voz no se escuche lejana.",
    "El audio queda mas fuerte y uniforme para videos hablados de redes sociales.",
    "Si un video no tiene pista de audio, el modulo se omite sin romper el flujo."
  ]
}
